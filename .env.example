# =============================================================================
# 环境变量示例（复制为 .env 后填写真实值）
# 本文件列出博客全部可选功能所需的变量。不填则对应功能自动降级/关闭。
# 部署到 EdgeOne Pages 时，在「环境变量」中配置同样的键即可。
# =============================================================================

# -----------------------------------------------------------------------------
# 文章朗读（Edge TTS 预生成 mp3 → Cloudflare R2）
# 不配置则 `audio: true` 的文章不会生成音频，播放器不显示。
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket
R2_PUBLIC_URL=https://r2.qiyuan.icu

# -----------------------------------------------------------------------------
# 自建评论系统（评论存 Cloudflare KV，图片存 Cloudflare R2）
# 不配置则评论接口返回 503；把 config/site.yaml 的 comment.provider 设为 'none' 可关闭。
# -----------------------------------------------------------------------------
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_KV_NAMESPACE_ID=your-kv-namespace-id
CF_KV_API_TOKEN=your-cloudflare-api-token

# -----------------------------------------------------------------------------
# 站内 AI 助手 / RAG
# 向量库 Neon(pgvector) + 硅基流动嵌入 + 生成模型
# 不配置则 /api/chat 不可用；把 config/site.yaml 的 rag.enabled 设为 false 可关闭。
# -----------------------------------------------------------------------------
SILICONFLOW_API_KEY=your-siliconflow-api-key
NEON_SERVERLESS_URL=postgres://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
MOONSHOT_API_KEY=your-moonshot-api-key

# -----------------------------------------------------------------------------
# 资源站（Supabase Storage + pgvector 混合检索）
# 不配置则 /api/resources 不可用；把 config/site.yaml 的 resources.enabled 设为 false 可关闭。
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# 博客图床（/api/images/upload 上传文章配图，对应文章页图片）
# 不配置则文章图片走本地静态资源。
# -----------------------------------------------------------------------------
PUBLISH_KEY=your-publish-key

# -----------------------------------------------------------------------------
# 上传 Worker（资源站商品图直传 R2 的代理 Worker）
# 不配置则资源站商品图上传失败。
# -----------------------------------------------------------------------------
UPLOAD_WORKER_URL=https://s3.qiyuan.icu
UPLOAD_WORKER_KEY=your-upload-worker-key

# -----------------------------------------------------------------------------
# 本地开发：资源站 API 代理目标（可选）
# 默认 https://resources.qiyuan.icu，可在此覆盖。
# -----------------------------------------------------------------------------
RESOURCES_API_PROXY=https://resources.qiyuan.icu

# -----------------------------------------------------------------------------
# 统计（可选）
# -----------------------------------------------------------------------------
# UMAMI_ID=your-umami-id
# UMAMI_ENDPOINT=https://stats.example.com
# GOOGLE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
